# Validator Agent Configuration
# RPC endpoint for the EVM app (read + tx submission)
RPC_URL=http://app-evm-validator:3003
# WebSocket for real-time event watch (optional, falls back to polling)
WS_URL=
# Path to the encrypted keystore
KEYSTORE_PATH=/app/secrets/keystore.enc
# Passphrase for keystore (set via env or enter interactively)
KEYSTORE_PASSPHRASE=
# Platform contract address
CONTRACT_ADDRESS=
# Agent network configuration
AGENT_HOST=0.0.0.0
AGENT_PORT=26658
AGENT_PROTOCOL=tcp
# Tendermint configuration
TENDERMINT_HOME=/tendermint
PROXY_APP=tcp://app-abci-validator:26658
# P2P configuration (passed through from validator env)
P2P_NODE_NAME=graphene-test-validator-node
P2P_SEEDS=
P2P_PERSISTENT_PEERS=
P2P_PRIVATE_PEER_IDS=
P2P_PEX=false
# Poll interval in ms
POLL_INTERVAL_MS=15000
