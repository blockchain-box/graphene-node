# Sentry Agent Configuration
# RPC endpoint for the EVM app (read-only)
RPC_URL=http://app-evm-sentry:3003
# WebSocket for real-time event watch (optional, falls back to polling)
WS_URL=ws://app-abci-sentry:3002/graphene/tx-watch
# Path to sentry secrets JSON file
SECRETS_PATH=/app/secrets/sentry-secrets.json
# Port range for local loopback tunnel endpoints
PORT_RANGE_START=40001
PORT_RANGE_END=40999
# Tendermint configuration
TENDERMINT_CONFIG_PATH=/tendermint/config/config.toml
TENDERMINT_CONTAINER=sentry-node
# Docker socket for container restart
DOCKER_SOCKET=/var/run/docker.sock
# Agent state directory (port map, tunnel state)
STATE_PATH=/app/state
# Poll interval in ms
POLL_INTERVAL_MS=15000
# Log file path
LOG_PATH=/app/logs/sentry-agent.log
